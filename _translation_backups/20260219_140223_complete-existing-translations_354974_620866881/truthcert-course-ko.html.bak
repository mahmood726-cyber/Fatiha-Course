<!-- Slide 10.20: Final Refrain -->
<div class="slide black">
<div class="content text-center">
<div class="refrain warning animate">
                  "그리고 그들이 확인하지 않았을 때,<br/>
                  when they trusted without checking,<br/>
                  명망 높은 사람은 절대 오류가 없다고 생각했을 때-<br/>
<br/>
                  숫자는 그대로 남아 있었고,<br/>
                  그리고 사람들은 그 대가를 치렀습니다."
                </div>
<div class="gold-line animate delay-2"></div>
<div class="refrain hope animate delay-3">
                  "But when they demanded proof,<br/>
                  when they shared their data,<br/>
                  when they replicated before they trusted—<br/>
<br/>
                  진실이 드러났고,<br/>
                  피해를 예방했고,<br/>
                  그리고 지식이 발전했습니다."
                </div>
</div>
</div>
</div>
<!-- Slide Navigation -->
<div class="slide-nav">
<button class="nav-btn" onclick="prevSlide()">←</button>
<div class="nav-center">
<div class="slide-counter" id="slideCounter">1 / 6</div>
<div class="progress" id="progressDots"></div>
</div>
<button class="nav-btn" onclick="nextSlide()">→</button>
</div>
</div>
</div>
</main>
</div>
<script>
    function toggleSidebar() {
      document.querySelector('.sidebar').classList.toggle('open');
      var overlay = document.querySelector('.sidebar-overlay');
      if (overlay) overlay.classList.toggle('show');
      var btn = document.querySelector('.mobile-menu-toggle, .sidebar-toggle, .hamburger');
      if (btn) btn.setAttribute('aria-expanded', btn.getAttribute('aria-expanded') === 'true' ? 'false' : 'true');
    }

    const modules = [
      { id: 1, title: "The Warning", subtitle: "When certainty kills", slides: 6 },
      { id: 2, title: "The Lands", subtitle: "Thirteen nations", slides: 5 },
      { id: 3, title: "The Solution", subtitle: "숫자에 치중", slides: 7 },
      { id: 4, title: "The Method", subtitle: "Measuring worth", slides: 6 },
      { id: 5, title: "The Discipline", subtitle: "Reproducibility", slides: 5 },
      { id: 6, title: "For Leaders", subtitle: "Executive summary", slides: 4 },
      { id: 7, title: "Hands-On", subtitle: "첫 번째 분석", slides: 5 },
      { id: 8, title: "Sustainability", subtitle: "Limits & longevity", slides: 3 },
      { id: 9, title: "Test & Sources", subtitle: "Quiz + references", slides: 6 },
      { id: 10, title: "Real Stories", subtitle: "역사에서 얻은 증거", slides: 20 }
    ];

    let currentModule = 1;
    let currentSlide = 1;
    const completedModules = new Set();

    function init() {
      renderModuleList();
      updateSlideNav();

      document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowRight' || e.key === ' ') {
          e.preventDefault();
          nextSlide();
        } else if (e.key === 'ArrowLeft') {
          e.preventDefault();
          prevSlide();
        }
      });
    }

    function renderModuleList() {
      const list = document.getElementById('moduleList');
      list.innerHTML = modules.map(m => `
        <div class="module-item ${m.id === currentModule ? 'active' : ''} ${completedModules.has(m.id) ? 'completed' : ''}"
             onclick="goToModule(${m.id})" tabindex="0" role="button" aria-label="Module ${m.id}: ${m.title}"
             onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();goToModule(${m.id});}">
          <div class="module-number">${completedModules.has(m.id) ? '&#10003;' : m.id}</div>
          <div class="module-info">
            <div class="module-title">${m.title}</div>
            <div class="module-subtitle">${m.subtitle}</div>
          </div>
        </div>
      `).join('');
    }

    function goToModule(moduleId) {
      if (moduleId > currentModule) completedModules.add(currentModule);
      currentModule = moduleId;
      currentSlide = 1;

      document.querySelectorAll('.module-slides').forEach(el => el.classList.remove('active'));
      document.querySelector(`.module-slides[data-module="${moduleId}"]`).classList.add('active');

      updateSlideVisibility();
      updateSlideNav();
      renderModuleList();
      document.getElementById('currentModule').textContent = modules[moduleId - 1].title;
    }

    function updateSlideVisibility() {
      const moduleSlides = document.querySelector(`.module-slides[data-module="${currentModule}"]`);
      const slides = moduleSlides.querySelectorAll('.slide');
      slides.forEach((slide, index) => slide.classList.toggle('active', index + 1 === currentSlide));
    }

    function updateSlideNav() {
      const module = modules[currentModule - 1];
      document.getElementById('slideCounter').textContent = `${currentSlide} / ${module.slides}`;
      document.getElementById('progressDots').innerHTML = Array.from({ length: module.slides }, (_, i) =>
        `<div class="progress-dot ${i + 1 === currentSlide ? 'active' : ''}" onclick="goToSlide(${i + 1})"></div>`
      ).join('');
    }

    function goToSlide(slideNum) {
      currentSlide = slideNum;
      updateSlideVisibility();
      updateSlideNav();
    }

    function nextSlide() {
      const module = modules[currentModule - 1];
      if (currentSlide < module.slides) {
        currentSlide++;
        updateSlideVisibility();
        updateSlideNav();
      } else if (currentModule < modules.length) {
        goToModule(currentModule + 1);
      }
    }

    function prevSlide() {
      if (currentSlide > 1) {
        currentSlide--;
        updateSlideVisibility();
        updateSlideNav();
      } else if (currentModule > 1) {
        const prevModuleSlides = modules[currentModule - 2].slides;
        currentModule--;
        currentSlide = prevModuleSlides;

        document.querySelectorAll('.module-slides').forEach(el => el.classList.remove('active'));
        document.querySelector(`.module-slides[data-module="${currentModule}"]`).classList.add('active');

        updateSlideVisibility();
        updateSlideNav();
        renderModuleList();
        document.getElementById('currentModule').textContent = modules[currentModule - 1].title;
      }
    }

    function checkAnswer(element, isCorrect) {
      const container = element.closest('.quiz-container');
      const options = container.querySelectorAll('.quiz-option');
      const feedback = container.querySelector('.quiz-feedback');

      options.forEach(opt => {
        opt.style.pointerEvents = 'none';
        if (opt === element) opt.classList.add(isCorrect ? 'correct' : 'incorrect');
      });

      feedback.classList.add('show', isCorrect ? 'correct' : 'incorrect');
      feedback.textContent = isCorrect
        ? '정확합니다. 이해하셨습니다.'
        : '정확하지 않습니다. 당신이 들었던 이야기를 생각해보십시오.';
    }

    init();
  </script>
</body>
</html>
