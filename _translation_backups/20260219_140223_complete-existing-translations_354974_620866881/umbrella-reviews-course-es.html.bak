      }},
      { type: "decision", theme: "dark", content: {
        icon: "SS", title: "Escenario: Revisión de alcance", xp: 25,
        scenario: "Durante la selección, encontrará una revisión de alcance bien realizada que mapea la evidencia sobre su tema pero no agrupa el efecto. tamaños.",
        question: "¿Deberías incluirlo en tu revisión general?",
        options: [
          { letter: "A", text: "Yes, include all review types", correct: false },
