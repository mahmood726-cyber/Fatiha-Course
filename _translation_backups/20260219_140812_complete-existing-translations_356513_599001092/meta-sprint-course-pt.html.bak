<script>
// ===== GAMIFICATION STATE =====
const DEFAULT_STATE = {
  xp: 0,
  level: 1,
  streak: 0,
  lastActive: null,
  correctAnswers: 0,
  decisionsCompleted: 0,
  predictionsCorrect: 0,
  predictionsTotal: 0,
  badges: [],
  completedModules: [],
  perfectModules: [],
  answeredQuestions: {},
  consecutiveCorrect: 0
};

// Safe localStorage with fallback
function safeGetStorage(key, fallback) {
  try {
    const item = localStorage.getItem(key);
    return item ? JSON.parse(item) : fallback;
  } catch (e) {
    console.warn('localStorage unavailable, using session storage');
    return fallback;
  }
}

function safeSetStorage(key, value) {
  try {
    localStorage.setItem(key, JSON.stringify(value));
  } catch (e) {
    console.warn('Could not save to localStorage');
  }
}

// Migration from old storage key to versioned key
(function migrateStorage() {
  try {
    const oldData = localStorage.getItem('metasprintGame');
    if (oldData && !localStorage.getItem('metasprintGame_v1')) {
      localStorage.setItem('metasprintGame_v1', oldData);
      localStorage.removeItem('metasprintGame');
    }
  } catch (e) {}
})();

let gameState = safeGetStorage('metasprintGame_v1', DEFAULT_STATE);

const LEVELS = [
  { level: 1, title: "Novice Analyst", icon: "📊", xp: 0 },
  { level: 2, title: "Protocol Apprentice", icon: "📋", xp: 100 },
  { level: 3, title: "Search Specialist", icon: "🔍", xp: 250 },
  { level: 4, title: "Extraction Expert", icon: "📝", xp: 450 },
  { level: 5, title: "Analysis Adept", icon: "📈", xp: 700 },
  { level: 6, title: "Quality Guardian", icon: "🛡️", xp: 1000 },
  { level: 7, title: "Evidence Master", icon: "🏆", xp: 1400 },
  { level: 8, title: "Meta-Analysis Sage", icon: "👑", xp: 1900 }
];

const BADGES = [
  { id: "first_blood", icon: "🎯", name: "First Blood", desc: "Responda sua primeira pergunta corretamente" },
  { id: "perfect_5", icon: "⭐", name: "Five Star", desc: "Get 5 correct answers in a row" },
  { id: "decision_maker", icon: "⚖️", name: "Decision Maker", desc: "Conclua 10 árvores de decisão" },
  { id: "oracle", icon: "🔮", name: "The Oracle", desc: "Predict 5 outcomes correctly" },
  { id: "protocol_pro", icon: "📋", name: "Protocol Pro", desc: "Conclua o módulo da Fase A" },
  { id: "search_savant", icon: "🔍", name: "Search Savant", desc: "Conclua o módulo da Fase B" },
  { id: "data_detective", icon: "🕵️", name: "Data Detective", desc: "Conclua o módulo da Fase C" },
  { id: "stats_wizard", icon: "🧙", name: "Stats Wizard", desc: "Conclua a Fase D módulo" },
  { id: "finisher", icon: "🏁", name: "Finisher", desc: "Concluir o curso inteiro" },
  { id: "streak_3", icon: "🔥", name: "On Fire", desc: "Maintain a 3-day streak" },
  { id: "streak_7", icon: "💫", name: "Weekly Warrior", desc: "Maintain a 7-day streak" },
  { id: "colchicine_hero", icon: "💊", name: "Colchicine Hero", desc: "Concluir o estudo de caso" }
];

// ===== MODULES DATA =====
const MODULES = [
  {
    id: 1, title: "Why META-SPRINT?", subtitle: "O custo de evidências ruins", xp: 150,
    slides: [
      { type: "title", theme: "dark", content: { title: "Why META-SPRINT?", subtitle: "O custo de errar" }},
      { type: "objectives", theme: "dark", content: {
        objectives: [
          "Understand why bad evidence causes real harm",
          "Aprenda com a tragédia CAST e Poldermans fraude",
          "Recognize surrogate outcome traps",
          "Understand what provenance verification means"
        ],
        tip: "Este módulo prepara o cenário para tudo o que se segue."
      }},
      { type: "prediction", theme: "dark", content: {
        icon: "🔮", title: "Faça sua previsão",
        subtitle: "Na década de 1980, foram desenvolvidos medicamentos para suprimir batimentos cardíacos irregulares (PVCs) após ataques cardíacos. Os medicamentos corrigiram com sucesso as leituras de ECG. O que você acha que aconteceu com as taxas de mortalidade?",
        options: [
          { id: "benefit", label: "💚 Deaths decreased", text: "As drogas salvaram vidas" },
          { id: "neutral", label: "⚪ No change", text: "As mortes permaneceram as mesmas" },
          { id: "harm", label: "❤️ Deaths increased", text: "As drogas causaram danos" }
        ],
        answer: "harm",
        xp: 30
      }},
      { type: "story", theme: "red-bg", content: {
        label: "A tragédia CAST", title: "50,000 Deaths",
        text: "The drugs that 'fixed' the ECG <strong>tripled</strong> death rates. 50,000 Americans died from drugs that made their monitors look better.",
        followup: "Suppressing PVCs was a surrogate outcome—it looked like benefit but masked real harm."
      }},
      { type: "decision", theme: "dark", content: {
        icon: "📊", title: "Cenário: O impressionante Números",
        xp: 25,
        scenario: "Um novo medicamento para diabetes mostra que reduz a HbA1c (marcador de açúcar no sangue) em 40% mais do que o tratamento padrão. O fabricante deseja acelerar a aprovação com base nesses 'dados de eficácia impressionantes'.",
        question: "What should regulators demand?",
        options: [
          { letter: "A", text: "Approve it—40% better HbA1c is significant", correct: false },
          { letter: "B", text: "Require trials showing reduced heart attacks, strokes, or death", correct: true },
          { letter: "C", text: "Aprovar com monitoramento pós-comercialização", correct: false },
          { letter: "D", text: "Request larger HbA1c trials for confirmation", correct: false }
        ],
        feedback: {
          correct: "Correct! HbA1c is a surrogate like PVCs. The CAST tragedy taught us: surrogates can improve while patients die. Demand patient-important outcomes.",
          incorrect: "HbA1c is a surrogate marker. CAST showed us that 'fixing' lab values can mask fatal harm. Always demand patient-important outcomes: death, heart attack, stroke."
        }
      }},
      { type: "stats", theme: "dark", content: {
        title: "A escala de falhas nas evidências",
        stats: [
          { value: "50,000", label: "CAST drug deaths" },
          { value: "800,000", label: "Poldermans fraud deaths" },
          { value: "70%", label: "Studies unreproducible" }
        ],
        caption: "Esses não são desastres raros. Eles são resultados previsíveis de processos interrompidos."
      }},
      { type: "story", theme: "dark", content: {
        label: "O cálculo do Vioxx", title: "The Memo They Tried to Hide",
        text: "In 1996, Merck scientists discovered their painkiller Vioxx caused heart attacks. They wrote internal memos. They calculated the excess deaths. They did <strong>nothing</strong>. For eight years, doctors prescribed Vioxx while Merck executives debated how to spin the data.",
        followup: "When the truth emerged in 2004: 88,000 Americans had suffered heart attacks. 38,000 died. One internal email read: 'The cardiovascular events are clearly there.' They knew. They waited. People died."
      }},
      { type: "decision", theme: "dark", content: {
        icon: "📧", title: "Cenário: o sinal interno",
        xp: 25,
        scenario: "Você é um pesquisador de uma empresa farmacêutica. Sua análise mostra que seu medicamento de grande sucesso aumenta os eventos cardíacos em 31%. Seu gerente sugere 'esperar por mais dados' e 'explorar interpretações alternativas' antes de escalar.",
        question: "O que você deve fazer?",
        options: [
          { letter: "A", text: "Aguarde por mais dados conforme sugerido", correct: false },
          { letter: "B", text: "Relate as descobertas imediatamente ao conselho de segurança", correct: true },
          { letter: "C", text: "Run alternative analyses to see if the signal disappears", correct: false },
          { letter: "D", text: "Document your concerns in an email but take no action", correct: false }
        ],
        feedback: {
          correct: "Correct! The Vioxx lesson: 'waiting for more data' while people die is a decision that kills. Safety signals require immediate escalation.",
          incorrect: "Cada dia de atraso tem uma contagem de corpos. Os memorandos internos da Vioxx mostraram que eles sabiam – mas “esperar por mais dados” matou 38 mil pessoas. Relate sinais de segurança imediatamente."
        }
      }},
      { type: "story", theme: "red-bg", content: {
        label: "O engano do Tamiflu", title: "£ 473 milhões para dados ocultos",
        text: "In 2009, governments stockpiled Tamiflu for pandemic flu. The UK spent £473 million. The evidence? Manufacturer-funded trials showing 'reduced complications.' The catch? Roche refused to release the full trial data for <strong>five years</strong>.",
        followup: "When researchers finally obtained the raw data, they found: No evidence Tamiflu reduced hospitalizations. No evidence it prevented complications. Half a billion pounds spent on a promise that couldn't be verified."
      }},
      { type: "decision", theme: "dark", content: {
        icon: "⚠️", title: "Cenário: os dados de Poldermans",
        xp: 25,
        scenario: "Você está revisando uma meta-análise e percebe que um pesquisador contribuiu com 15 dos 40 incluídos estudos. Seus dados mostram resultados dramaticamente melhores do que outros. Ninguém verificou a existência de seus dados brutos.",
        question: "O que você deve fazer?",
        options: [
          { letter: "A", text: "Inclua todos os estudos - eles foram aprovados na revisão por pares", correct: false },
          { letter: "B", text: "Solicite verificação de proveniência para seus estudos", correct: true },
          { letter: "C", text: "Exclude his studies without explanation", correct: false },
          { letter: "D", text: "Faça a média de seus resultados com outros para reduzir o impacto", correct: false }
        ],
        feedback: {
          correct: "Correto! A verificação de proveniência pergunta 'Posso rastrear este número até sua origem?' A fraude de Poldermans matou 800.000 pessoas porque ninguém fez essa pergunta.",
          incorrect: "Not quite. Peer review doesn't verify raw data exists. You need provenance—the trail from number to source document."
        }
      }},
      { type: "story", theme: "dark", content: {
        label: "O engano Theranos", title: "One Drop of Blood, Billions in Lies",
        text: "In 2003, a 19-year-old Stanford dropout named <strong>Elizabeth Holmes</strong> made a promise that captivated the world: revolutionary blood tests from a single drop. No more needles. No more vials. Investors poured in $700 million. Walgreens signed a deal to put Theranos machines in 8,200 stores. Holmes graced magazine covers. Her company was valued at $9 billion.",
        followup: "The technology never worked. Not once. Theranos ran patient samples on competitors' machines, then hid the results. When the lies unraveled in 2015, the damage was done: <strong>thousands of patients received incorrect diagnoses</strong>. Cancer missed. HIV false positives. Treatment decisions based on fabricated data. Holmes is now serving 11 years in federal prison. The lesson: extraordinary claims without verifiable evidence aren't innovation—they're fraud."
      }},
      { type: "decision", theme: "dark", content: {
        icon: "🩸", title: "Cenário: a tecnologia revolucionária",
        xp: 25,
        scenario: "Uma startup afirma que sua IA pode detectar 50 tipos de câncer a partir de uma única coleta de sangue com 99% de precisão. Eles arrecadaram US$ 500 milhões. O endosso de celebridades é abundante. Mas recusam-se a publicar os seus dados de validação, citando “segredos comerciais”. Um sistema hospitalar deseja implantá-lo imediatamente.",
        question: "What should the hospital demand before deployment?",
        options: [
          { letter: "A", text: "Confie na aprovação da FDA e implante", correct: false },
          { letter: "B", text: "Require independent validation on their own patient population", correct: true },
          { letter: "C", text: "Comece com um pequeno piloto baseado nos dados da empresa", correct: false },
          { letter: "D", text: "Aguarde publicações revisadas por pares", correct: false }
        ],
        feedback: {
          correct: "Correto! Theranos obteve aprovação da FDA para um teste, enquanto mentia sobre dezenas de outros. A validação independente em SEUS pacientes não é negociável. Segredos comerciais que ocultam dados de validação são sinais de alerta.",
          incorrect: "Theranos fooled Walgreens, investors, and patients. The lesson: no independent validation, no deployment. 'Trust us' is not evidence."
        }
      }},
      { type: "story", theme: "red-bg", content: {
        label: "A catástrofe do OxyContin", title: "A pílula que criou uma epidemia",
        text: "In 1996, Purdue Pharma launched OxyContin with a bold claim: their new opioid was <strong>'less than 1% addictive.'</strong> They cited a brief letter to the editor in a 1980 New England Journal of Medicine—five sentences about hospital patients, not outpatient prescriptions. Sales reps repeated the claim 500,000 times to doctors. Purdue spent $200 million marketing it as safe.",
        followup: "The Sackler family knew. Internal documents showed they tracked addiction reports. They knew their 12-hour pill was wearing off early, driving patients to take more. They did the math: more pills, more profit. By 2021: <strong>500,000 Americans dead from opioid overdoses</strong>. Purdue pleaded guilty to federal charges—twice. The Sacklers paid $6 billion but admitted no personal wrongdoing. One misrepresented paragraph. Half a million graves."
      }},
      { type: "decision", theme: "dark", content: {
        icon: "💊", title: "Cenário: a perseguição de citações",
        xp: 25,
        scenario: "Um representante de drogas afirma que seu novo analgésico tem 'risco mínimo de dependência, comprovado na literatura. Eles lhe entregam uma referência. Você descobre que é uma carta de 5 frases ao editor de 1980, estudando pacientes hospitalizados, não a população ambulatorial que você trata.",
        question: "O que você deve fazer?",
        options: [
          { letter: "A", text: "It's in NEJM, so it's credible enough", correct: false },
          { letter: "B", text: "Demand RCTs with addiction as a pre-specified outcome in relevant populations", correct: true },
          { letter: "C", text: "Prescribe cautiously and monitor patients yourself", correct: false },
          { letter: "D", text: "Wait for colleagues to report problems first", correct: false }
        ],
        feedback: {
