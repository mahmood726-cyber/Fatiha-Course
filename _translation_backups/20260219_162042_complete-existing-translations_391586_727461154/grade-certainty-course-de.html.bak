          { letter: "B", text: "NIEDRIG – Beobachtungsstudie mit gravierenden Einschränkungen", correct: false },
          { letter: "C", text: "VERY LOW—critical risk of bias, serious imprecision; communicate uncertainty clearly", correct: true },
          { letter: "D", text: "Cannot rate—more studies needed before any assessment", correct: false }
